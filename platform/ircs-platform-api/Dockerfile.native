FROM ghcr.io/graalvm/native-image-community:25 AS builder
WORKDIR /workspace
COPY . .
RUN chmod +x gradlew && ./gradlew --no-daemon :platform:ircs-platform-api:nativeCompile

FROM gcr.io/distroless/base-debian12:nonroot
WORKDIR /app
COPY --from=builder /workspace/platform/ircs-platform-api/build/native/nativeCompile/ircs-platform-api /app/ircs-platform-api
EXPOSE 8080
ENTRYPOINT ["/app/ircs-platform-api"]

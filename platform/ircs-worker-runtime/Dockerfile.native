# syntax=docker/dockerfile:1.7
FROM ghcr.io/graalvm/native-image-community:25 AS builder
WORKDIR /workspace
COPY . .
RUN --mount=type=cache,target=/root/.gradle \
    chmod +x gradlew && ./gradlew --no-daemon :platform:ircs-worker-runtime:nativeCompile

FROM gcr.io/distroless/base-debian12:nonroot
WORKDIR /app
COPY --from=builder /workspace/platform/ircs-worker-runtime/build/native/nativeCompile/ircs-worker-runtime /app/ircs-worker-runtime
EXPOSE 8080
ENTRYPOINT ["/app/ircs-worker-runtime"]
